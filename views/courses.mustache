
{{> head}}
{{> header}}

<div class="wrap">

  <form method="GET" action="/courses">
    <select name="level">
      <option value="" {{^filters.level}}selected{{/filters.level}}>Any</option>
      <option value="beginner" {{#filters.level}}{{#isBeginner}}selected{{/isBeginner}}{{/filters.level}}>Beginner</option>
    </select>

    <label>
      Search
      <input type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
    </label>

    <button class="btn" type="submit">Apply</button>
    <a href="/courses">Reset</a>
  </form>

  <div class="cards">
    {{#courses}}
    <article class="card">
  <h2 class="course-title">
    <a href="/courses/{{id}}" class="course-link">
      {{title}}
    </a>
  </h2>

  <p class="muted">
    Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
  </p>

  <p>{{description}}</p>

  <p class="muted">Dates: {{startDate}} – {{endDate}}</p>

  <p class="muted">
    Next session: {{nextSession}} • Sessions: {{sessionsCount}}
  </p>

  <a href="/courses/{{id}}" class="button">View & Book</a>
</article>
    {{/courses}}

    {{^courses}}
      <p>No courses match your filters.</p>
    {{/courses}}
  </div>

</div>

{{> footer}}