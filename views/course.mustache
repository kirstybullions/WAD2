{{> head}}
<link rel="stylesheet" href="/css/style.css">
{{> header}}

<article>
  <h1>{{course.title}}</h1>

  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>

  <p>{{course.description}}</p>

  <p class="muted">Dates: {{startDate}} – {{endDate}}</p>

  <p><strong>Location:</strong> {{course.location}}</p>
  <p><strong>Price:</strong> £{{course.price}}</p>

  <section>
    <h2>Book the full course</h2>
    <form action="/courses/{{course._id}}/book" method="post">
      <input type="hidden" name="userId" value="{{user._id}}">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Start</th>
          <th>End</th>
          <th>Capacity</th>
          <th>Booked</th>
          <th>Remaining</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{startFormatted}}</td>
          <td>{{endFormatted}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#../course.allowDropIn}}
            <form action="/sessions/{{id}}/book" method="post">
              <input type="hidden" name="userId" value="{{../user._id}}">
              <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>Book this session</button>
            </form>
            {{/../course.allowDropIn}}

            {{^../course.allowDropIn}}
              <span class="muted">Drop-ins disabled</span>
            {{/../course.allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}