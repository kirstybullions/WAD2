{{> head}}
{{> header}}

<div class="wrap">
<h1>Login</h1>

{{#error}}
<p class="error">{{error}}</p>
{{/error}}

<form method="POST" action="/login">
    <label>Email</label>
    <input type="email" name="email" required>

    <label>Password</label>
    <input type="password" name="password" required>

    <button type="submit">Login</button>
</form>